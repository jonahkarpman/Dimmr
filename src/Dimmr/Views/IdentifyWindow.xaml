<Window x:Class="Dimmr.Views.IdentifyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#CC0A0A0A"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        ShowActivated="False"
        Focusable="False"
        WindowStartupLocation="Manual">
    <Border BorderBrush="{DynamicResource AccentBrush}" BorderThickness="4" Margin="60">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="NumberText" FontFamily="Consolas" FontSize="200"
                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" />
            <TextBlock x:Name="LabelText" FontFamily="Consolas" FontSize="26"
                       Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>
