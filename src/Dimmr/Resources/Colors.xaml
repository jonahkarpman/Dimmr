<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Pip-Boy terminal palette (from the dimmr SPEC design language) -->
    <Color x:Key="BackgroundColor">#0A0A0A</Color>
    <Color x:Key="SurfaceColor">#0D1A0D</Color>
    <Color x:Key="PrimaryTextColor">#33FF33</Color>
    <Color x:Key="SecondaryTextColor">#1A8C1A</Color>
    <Color x:Key="AccentColor">#00FF41</Color>
    <Color x:Key="DangerColor">#FF8800</Color>
    <Color x:Key="BorderColor">#1A4D1A</Color>
    <Color x:Key="DisabledColor">#0D3D0D</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource DisabledColor}" />
    <SolidColorBrush x:Key="HoverBrush" Color="#3333FF33" />

</ResourceDictionary>
