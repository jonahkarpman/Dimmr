<Window x:Class="Dimmr.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Dimmr.Converters"
        Title="DIMMR"
        Width="440" Height="640"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBool" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{DynamicResource BackgroundBrush}" x:Name="TitleBar" Height="34">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleText" Text="{Binding AppTitle}" Foreground="{DynamicResource AccentBrush}"
                           FontFamily="Consolas" FontSize="14" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FF41" BlurRadius="10" ShadowDepth="0" Opacity="0.8" />
                    </TextBlock.Effect>
                </TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Click="OnOpenSettings" Width="30" Height="30" MinHeight="0" Padding="0" Margin="0"
                            Tag="no-sound" AutomationProperties.Name="Settings">
                        <Path Width="15" Height="15" Stretch="Uniform"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.82,11.69,4.82,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" />
                    </Button>
                    <Button Content="[_]" Click="OnMinimize" Width="30" Height="30" MinHeight="0" Padding="0" Margin="2,0,0,0"
                            AutomationProperties.Name="Minimize" />
                    <Button Click="OnHide" Width="30" Height="30" MinHeight="0" Padding="0" Margin="2,0,0,0"
                            AutomationProperties.Name="Close to tray">
                        <TextBlock Text="[X]" Foreground="{DynamicResource DangerBrush}" FontFamily="Consolas" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,6,14,6">
                <StackPanel>

                    <!-- Dimming -->
                    <TextBlock Text="DIMMING" Style="{StaticResource HeaderText}" />
                    <CheckBox Content="Dimming on (global)" IsChecked="{Binding MasterOn}"
                              AutomationProperties.Name="Dimming on" />

                    <!-- Screens -->
                    <TextBlock Text="SCREENS" Style="{StaticResource HeaderText}" />
                    <Button Content="IDENTIFY SCREENS" Command="{Binding IdentifyCommand}" Margin="0,0,0,8"
                            AutomationProperties.Name="Identify screens" />
                    <ItemsControl ItemsSource="{Binding Screens}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Margin="0,0,0,8" Padding="8" Tag="glowbox">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00FF41" BlurRadius="8" ShadowDepth="0" Opacity="0" />
                                    </Border.Effect>
                                    <StackPanel>
                                        <CheckBox Content="{Binding Label}" IsChecked="{Binding Enabled}"
                                                  AutomationProperties.Name="Screen enabled" />
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Dim" VerticalAlignment="Center" Margin="0,0,8,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <Slider Grid.Column="1" Minimum="0" Maximum="85" Value="{Binding Dim}"
                                                    SmallChange="5" LargeChange="10" IsSnapToTickEnabled="True" TickFrequency="1"
                                                    AutomationProperties.Name="Screen dim level" />
                                            <TextBlock Grid.Column="2" Text="{Binding Dim, StringFormat={}{0}%}"
                                                       Width="44" TextAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                        <CheckBox Content="Auto-detect bounds" IsChecked="{Binding AutoBounds}"
                                                  Margin="0,6,0,0" AutomationProperties.Name="Auto detect bounds" />
                                        <Grid Margin="0,6,0,0" IsEnabled="{Binding AutoBounds, Converter={StaticResource InverseBool}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                <TextBlock Text="X" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                <TextBox Text="{Binding X}" AutomationProperties.Name="Bounds X" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="0,0,4,0">
                                                <TextBlock Text="Y" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                <TextBox Text="{Binding Y}" AutomationProperties.Name="Bounds Y" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Margin="0,0,4,0">
                                                <TextBlock Text="W" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                <TextBox Text="{Binding Width}" AutomationProperties.Name="Bounds width" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3">
                                                <TextBlock Text="H" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                <TextBox Text="{Binding Height}" AutomationProperties.Name="Bounds height" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Profiles -->
                    <TextBlock Text="PROFILE" Style="{StaticResource HeaderText}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                                  AutomationProperties.Name="Active profile" />
                        <Button Grid.Column="1" Command="{Binding SaveCommand}" Margin="6,0,0,0"
                                Width="34" Height="30" MinHeight="0" Padding="0"
                                ToolTip="Save changes to the selected profile" AutomationProperties.Name="Save profile">
                            <Path Width="14" Height="14" Stretch="Uniform" StrokeThickness="1.2" Fill="Transparent"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M2,2 L11,2 L14,5 L14,14 L2,14 Z M5,2 L5,6 L11,6 L11,2 M4,9 L12,9 L12,13 L4,13 Z" />
                        </Button>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="New profile name" />
                        <Button Grid.Column="1" Content="[+]" Command="{Binding SaveAsCommand}" Margin="6,0,0,0"
                                Width="34" Height="30" MinHeight="0" Padding="0"
                                Tag="no-sound" ToolTip="New profile from current settings" AutomationProperties.Name="New profile" />
                        <Button Grid.Column="2" Click="OnDeleteProfile" Margin="6,0,0,0"
                                Width="34" Height="30" MinHeight="0" Padding="0"
                                Tag="no-sound" ToolTip="Delete selected profile"
                                AutomationProperties.Name="Delete profile">
                            <TextBlock Text="[-]" Foreground="{DynamicResource DeleteBrush}" FontFamily="Consolas" />
                        </Button>
                    </Grid>
                    <Button Content="REFRESH MONITORS" Command="{Binding RefreshCommand}" Margin="0,8,0,0"
                            HorizontalAlignment="Left" />

                </StackPanel>
            </ScrollViewer>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" Padding="10,4">
                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"
                           Text="Win+Shift+D toggle  .  Win+Shift+PgUp more dim  .  Win+Shift+PgDn less dim" />
            </Border>

            <!-- Settings overlay -->
            <Grid x:Name="SettingsOverlay" Grid.RowSpan="3" Background="#C0000000"
                  Visibility="Collapsed" MouseLeftButtonDown="OnSettingsBackdrop">
                <Border Width="320" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1" Padding="16" MouseLeftButtonDown="OnSettingsPanelClick">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="SETTINGS" Style="{StaticResource HeaderText}" Margin="0" VerticalAlignment="Center" />
                            <Button Content="[X]" Click="OnCloseSettings" HorizontalAlignment="Right" MinHeight="0" Padding="8,2"
                                    Tag="no-sound" AutomationProperties.Name="Close settings" />
                        </Grid>

                        <TextBlock Text="STARTUP" Style="{StaticResource HeaderText}" />
                        <CheckBox Content="Run at startup" IsChecked="{Binding RunAtStartup}"
                                  AutomationProperties.Name="Run at startup" />
                        <CheckBox Content="Reset dim on startup" IsChecked="{Binding ResetDimOnStartup}"
                                  Margin="0,6,0,0" AutomationProperties.Name="Reset dim on startup" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="Start at" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                            <ComboBox ItemsSource="{Binding StartupDimOptions}" SelectedItem="{Binding StartupDim}"
                                      Width="80" AutomationProperties.Name="Startup dim value" />
                            <TextBlock Text="%" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>

                        <TextBlock Text="OPTIONS" Style="{StaticResource HeaderText}" />
                        <CheckBox Content="Sounds" IsChecked="{Binding SoundsEnabled}"
                                  AutomationProperties.Name="Sounds enabled" />
                        <CheckBox Content="Ambient hum" IsChecked="{Binding Hum}" Margin="0,6,0,0"
                                  AutomationProperties.Name="Ambient hum" />
                        <CheckBox Content="Scanlines" IsChecked="{Binding Scanlines}" Margin="0,6,0,0"
                                  AutomationProperties.Name="Scanlines" />
                        <CheckBox Content="Glow (breathing)" IsChecked="{Binding Glow}" Margin="0,6,0,0"
                                  AutomationProperties.Name="Breathing glow" />

                        <TextBlock Text="COLOR" Style="{StaticResource HeaderText}" />
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <RadioButton x:Name="SwatchGreen" Style="{StaticResource ColorSwatch}"
                                         GroupName="ColorScheme" Tag="Green" Background="#33FF33" Margin="0,0,8,0"
                                         Checked="OnSelectColor" AutomationProperties.Name="Green color"
                                         ToolTip="Phosphor green" />
                            <RadioButton x:Name="SwatchAmber" Style="{StaticResource ColorSwatch}"
                                         GroupName="ColorScheme" Tag="Amber" Background="#FFB642"
                                         Checked="OnSelectColor" AutomationProperties.Name="Amber color"
                                         ToolTip="New Vegas amber" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Scanline overlay (CRT effect): a 1px dark line every 3px. -->
            <Rectangle Grid.RowSpan="3" IsHitTestVisible="False"
                       RenderOptions.EdgeMode="Aliased"
                       Visibility="{Binding Scanlines, Converter={StaticResource BoolToVis}}">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile" Stretch="None"
                                  Viewport="0,0,3,3" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="Transparent">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,3,3" />
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="#40000000">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,3,1" />
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>
    </Border>
</Window>
